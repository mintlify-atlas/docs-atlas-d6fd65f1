  "publicApiSurface": [
    "forge - Main interactive mode",
    "forge --prompt - Direct prompt execution",
    "forge provider login - Configure AI providers",
    "forge provider logout - Remove provider credentials",
    "forge provider list - List available providers",
    "forge agent list - List available agents",
    "forge config get - Get configuration values",
    "forge config set - Set configuration values",
    "forge config list - List all configuration",
    "forge conversation list - List conversation history",
    "forge conversation show - Show conversation details",
    "forge conversation delete - Delete conversations",
    "forge workspace sync - Index workspace for semantic search",
    "forge workspace list - List indexed workspaces",
    "forge mcp add - Add MCP server",
    "forge mcp remove - Remove MCP server",
    "forge mcp list - List MCP servers",
    "forge cmd list - List custom commands",
    "forge cmd execute - Execute custom command",
    "forge commit - Generate AI commit messages",
    "forge suggest - Suggest shell commands from natural language",
    "forge info - Show configuration and status",
    "forge update - Update to latest version",
